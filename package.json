{
  "name": "mcp-whatsapp",
  "version": "2.0.0",
  "description": "MCP server for WhatsApp using QR code authentication (Baileys). Sends text, media up to ~15MB, document reminders and billing alerts.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mcp-whatsapp": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf build",
    "smoke": "node build/scripts/smoke.js"
  },
  "keywords": ["mcp", "whatsapp", "baileys", "qr", "messaging"],
  "author": "Fernando Taricano",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@whiskeysockets/baileys": "^6.7.8",
    "mime-types": "^2.1.35",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
