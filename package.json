{
  "name": "mcp-whatsapp",
  "version": "2.1.0",
  "description": "WhatsApp integration via Baileys (QR-code auth). Ships a CLI (`whatsapp`) for on-demand send and an MCP server (`mcp-whatsapp`) for long-running integrations.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mcp-whatsapp": "build/index.js",
    "whatsapp": "build/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "cli": "node build/cli.js",
    "dev": "tsc --watch",
    "clean": "rm -rf build",
    "smoke": "node build/scripts/smoke.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit:ci": "npm audit --audit-level=high"
  },
  "keywords": ["mcp", "whatsapp", "baileys", "qr", "messaging"],
  "author": "Fernando Taricano",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@whiskeysockets/baileys": "^6.7.8",
    "mime-types": "^2.1.35",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "engines": {
    "node": ">=18.3.0"
  }
}
