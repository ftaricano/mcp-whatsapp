# mcp-whatsapp (Baileys / QR) — todas as variáveis são OPCIONAIS.
# Defaults são sensatos; só ajuste se precisar.

# Diretório onde a sessão do WhatsApp é persistida (arquivos de credenciais).
# Default: ./auth-state (relativo ao cwd). NUNCA commite esse diretório.
# WHATSAPP_SESSION_DIR=./auth-state

# Diretórios de onde arquivos podem ser anexados (path traversal guard).
# Formato: lista separada por ":" (estilo PATH). Aceita ~ para home.
# Default: [HOME, CWD]. Ajuste só se precisar restringir ou liberar caminhos.
# WHATSAPP_ALLOWED_DIRS=~/documentos:~/boletos

# Rate limiting (conservador — para não parecer spam).
# Mensagens de texto por segundo (default: 2).
# WHATSAPP_RATE_LIMIT_MESSAGES=2
# Mensagens de mídia por segundo (default: 1).
# WHATSAPP_RATE_LIMIT_MEDIA=1
# Burst máximo (default: 10).
# WHATSAPP_BURST_LIMIT=10

# Retry policy.
# WHATSAPP_MAX_RETRIES=3
# WHATSAPP_BASE_DELAY=1000
# WHATSAPP_MAX_DELAY=30000
# WHATSAPP_BACKOFF_MULTIPLIER=2

# Mídia.
# Tamanho máximo em bytes (default: 15MB).
# WHATSAPP_MAX_MEDIA_SIZE=15728640

# Logging: fatal | error | warn | info | debug | trace | silent
# AVISO: `trace`/`debug` podem logar payloads do Baileys incluindo material de
# sessão. Nunca cole logs trace/debug em bug reports públicos.
# WHATSAPP_LOG_LEVEL=info

# Código de país padrão quando o número vem sem DDI (default: 55 = Brasil).
# WHATSAPP_DEFAULT_COUNTRY_CODE=55
